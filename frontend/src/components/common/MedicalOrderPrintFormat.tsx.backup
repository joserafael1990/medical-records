// ============================================================================
// MEDICAL ORDER PRINT FORMAT - Formato de impresión para órdenes médicas
// Conforme a NOM-004-SSA3-2012
// ============================================================================

import React from 'react';
import {
  Box,
  Typography,
  Paper,
  Divider,
  Table,
  TableBody,
  TableCell,
  TableRow,
  Chip
} from '@mui/material';
import { Grid } from '@mui/material';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';
import { 
  MedicalOrder,
  Patient,
  Consultation 
} from '../../types';
import {
  ORDER_PRIORITIES,
  STUDY_TYPES
} from '../../constants';

interface MedicalOrderPrintFormatProps {
  order: MedicalOrder;
  patient?: Patient;
  consultation?: Consultation;
  doctorInfo?: {
    name: string;
    license: string;
    specialty: string;
    title: string;
  };
  clinicInfo?: {
    name: string;
    address: string;
    phone: string;
    email: string;
  };
}

const MedicalOrderPrintFormat: React.FC<MedicalOrderPrintFormatProps> = ({
  order,
  patient,
  consultation,
  doctorInfo,
  clinicInfo
}) => {
  const formatDate = (dateString: string) => {
    try {
      return format(new Date(dateString), 'dd/MM/yyyy', { locale: es });
    } catch {
      return 'Fecha inválida';
    }
  };

  const formatDateTime = (dateString: string) => {
    try {
      return format(new Date(dateString), 'dd/MM/yyyy HH:mm', { locale: es });
    } catch {
      return 'Fecha inválida';
    }
  };

  const getStudyTypeLabel = (studyType: string) => {
    const typeOption = STUDY_TYPES.find(t => t.value === studyType);
    return typeOption?.label || studyType;
  };

  const getPriorityLabel = (priority: string) => {
    const priorityOption = ORDER_PRIORITIES.find(p => p.value === priority);
    return priorityOption?.label || priority;
  };

  const getPriorityColor = (priority: string) => {
    const priorityOption = ORDER_PRIORITIES.find(p => p.value === priority);
    return priorityOption?.color || '#42a5f5';
  };

  return (
    <Paper 
      elevation={0} 
      sx={{ 
        p: 4, 
        maxWidth: '21cm', 
        minHeight: '29.7cm',
        margin: '0 auto',
        backgroundColor: 'white',
        fontSize: '12px',
        '@media print': {
          boxShadow: 'none',
          margin: 0,
          maxWidth: 'none',
          fontSize: '11px'
        }
      }}
    >
      {/* Header - Información de la Clínica */}
      <Box sx={{ textAlign: 'center', mb: 3 }}>
        <Typography variant="h5" fontWeight="bold" gutterBottom>
          {clinicInfo?.name || 'AVANT - Sistema Médico'}
        </Typography>
        <Typography variant="body2" color="textSecondary">
          {clinicInfo?.address || 'Dirección de la clínica'}
        </Typography>
        <Typography variant="body2" color="textSecondary">
          Tel: {clinicInfo?.phone || 'Teléfono'} | Email: {clinicInfo?.email || 'email@clinica.com'}
        </Typography>
      </Box>

      <Divider sx={{ mb: 3 }} />

      {/* Título del Documento */}
      <Box sx={{ textAlign: 'center', mb: 3 }}>
        <Typography variant="h4" fontWeight="bold" color="primary">
          ORDEN MÉDICA
        </Typography>
        <Typography variant="h6" color="textSecondary">
          {getStudyTypeLabel(order.study_type)}
        </Typography>
      </Box>

      {/* Información del Documento */}
      <Grid container spacing={2} sx={{ mb: 3 }}>
        <Grid xs={6}>
          <Typography variant="body2">
            <strong>No. de Orden:</strong> {order.id}
          </Typography>
        </Grid>
        <Grid xs={6} sx={{ textAlign: 'right' }}>
          <Typography variant="body2">
            <strong>Fecha:</strong> {formatDateTime(order.order_date)}
          </Typography>
        </Grid>
      </Grid>

      {/* Información del Paciente */}
      <Box sx={{ mb: 3 }}>
        <Typography variant="h6" fontWeight="bold" gutterBottom color="primary">
          DATOS DEL PACIENTE
        </Typography>
        <Table size="small">
          <TableBody>
            <TableRow>
              <TableCell sx={{ fontWeight: 'bold', width: '25%', border: 'none' }}>
                Nombre:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {patient ? `${patient.first_name} ${patient.paternal_surname} ${patient.maternal_surname || ''}`.trim() : order.patient_name || 'No especificado'}
              </TableCell>
              <TableCell sx={{ fontWeight: 'bold', width: '25%', border: 'none' }}>
                Fecha de Nacimiento:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {patient?.birth_date ? formatDate(patient.birth_date.toString()) : 'No especificado'}
              </TableCell>
            </TableRow>
            <TableRow>
              <TableCell sx={{ fontWeight: 'bold', border: 'none' }}>
                CURP:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {patient?.curp || 'No especificado'}
              </TableCell>
              <TableCell sx={{ fontWeight: 'bold', border: 'none' }}>
                Género:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {patient?.gender || 'No especificado'}
              </TableCell>
            </TableRow>
            <TableRow>
              <TableCell sx={{ fontWeight: 'bold', border: 'none' }}>
                Teléfono:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {patient?.phone || 'No especificado'}
              </TableCell>
              <TableCell sx={{ fontWeight: 'bold', border: 'none' }}>
                ID Paciente:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {order.patient_id}
              </TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </Box>

      <Divider sx={{ mb: 3 }} />

      {/* Información del Médico */}
      <Box sx={{ mb: 3 }}>
        <Typography variant="h6" fontWeight="bold" gutterBottom color="primary">
          MÉDICO SOLICITANTE
        </Typography>
        <Table size="small">
          <TableBody>
            <TableRow>
              <TableCell sx={{ fontWeight: 'bold', width: '25%', border: 'none' }}>
                Nombre:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {doctorInfo?.title || 'Dr.'} {order.ordering_doctor_name || 'No especificado'}
              </TableCell>
              <TableCell sx={{ fontWeight: 'bold', width: '25%', border: 'none' }}>
                Cédula Profesional:
              </TableCell>
              <TableCell sx={{ border: 'none' }}>
                {order.ordering_doctor_license || 'No especificado'}
              </TableCell>
            </TableRow>
            <TableRow>
              <TableCell sx={{ fontWeight: 'bold', border: 'none' }}>
                Especialidad:
              </TableCell>
              <TableCell sx={{ border: 'none', colspan: 3 }}>
                {order.ordering_doctor_specialty || 'Medicina General'}
              </TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </Box>

      <Divider sx={{ mb: 3 }} />

      {/* Detalles de la Orden */}
      <Box sx={{ mb: 3 }}>
        <Typography variant="h6" fontWeight="bold" gutterBottom color="primary">
          DETALLES DE LA ORDEN
        </Typography>
        
        <Grid container spacing={2} sx={{ mb: 2 }}>
          <Grid xs={8}>
            <Typography variant="body1" fontWeight="bold" gutterBottom>
              Estudio Solicitado:
            </Typography>
            <Typography variant="h6" sx={{ backgroundColor: '#f5f5f5', p: 2, borderRadius: 1 }}>
              {order.study_name}
            </Typography>
          </Grid>
          <Grid xs={4}>
            <Typography variant="body1" fontWeight="bold" gutterBottom>
              Prioridad:
            </Typography>
            <Chip
              label={getPriorityLabel(order.priority)}
              sx={{
                backgroundColor: getPriorityColor(order.priority),
                color: 'white',
                fontWeight: 'bold'
              }}
            />
          </Grid>
        </Grid>

        {order.study_description && (
          <Box sx={{ mb: 2 }}>
            <Typography variant="body1" fontWeight="bold" gutterBottom>
              Descripción del Estudio:
            </Typography>
            <Typography variant="body2" sx={{ backgroundColor: '#f9f9f9', p: 2, borderRadius: 1 }}>
              {order.study_description}
            </Typography>
          </Box>
        )}
      </Box>

      {/* Información Clínica */}
      <Box sx={{ mb: 3 }}>
        <Typography variant="h6" fontWeight="bold" gutterBottom color="primary">
          INFORMACIÓN CLÍNICA
        </Typography>
        
        <Box sx={{ mb: 2 }}>
          <Typography variant="body1" fontWeight="bold" gutterBottom>
            Indicación Clínica: *
          </Typography>
          <Typography variant="body2" sx={{ backgroundColor: '#f9f9f9', p: 2, borderRadius: 1, minHeight: 60 }}>
            {order.clinical_indication}
          </Typography>
        </Box>

        <Grid container spacing={2}>
          {order.provisional_diagnosis && (
            <Grid xs={8}>
              <Typography variant="body1" fontWeight="bold" gutterBottom>
                Diagnóstico Provisional:
              </Typography>
              <Typography variant="body2" sx={{ backgroundColor: '#f9f9f9', p: 2, borderRadius: 1 }}>
                {order.provisional_diagnosis}
              </Typography>
            </Grid>
          )}
          
          {order.diagnosis_cie10 && (
            <Grid xs={4}>
              <Typography variant="body1" fontWeight="bold" gutterBottom>
                Código CIE-10:
              </Typography>
              <Typography variant="h6" sx={{ backgroundColor: '#e3f2fd', p: 2, borderRadius: 1, textAlign: 'center' }}>
                {order.diagnosis_cie10}
              </Typography>
            </Grid>
          )}
        </Grid>

        {order.relevant_clinical_data && (
          <Box sx={{ mt: 2 }}>
            <Typography variant="body1" fontWeight="bold" gutterBottom>
              Datos Clínicos Relevantes:
            </Typography>
            <Typography variant="body2" sx={{ backgroundColor: '#f9f9f9', p: 2, borderRadius: 1 }}>
              {order.relevant_clinical_data}
            </Typography>
          </Box>
        )}
      </Box>

      {/* Instrucciones */}
      {(order.requires_preparation || order.preparation_instructions || order.special_instructions) && (
        <Box sx={{ mb: 3 }}>
          <Typography variant="h6" fontWeight="bold" gutterBottom color="primary">
            INSTRUCCIONES
          </Typography>
          
          {order.requires_preparation && order.preparation_instructions && (
            <Box sx={{ mb: 2 }}>
              <Typography variant="body1" fontWeight="bold" gutterBottom color="error">
                ⚠️ Preparación Requerida:
              </Typography>
              <Typography variant="body2" sx={{ backgroundColor: '#fff3e0', p: 2, borderRadius: 1, border: '1px solid #ff9800' }}>
                {order.preparation_instructions}
              </Typography>
            </Box>
          )}

          {order.special_instructions && (
            <Box sx={{ mb: 2 }}>
              <Typography variant="body1" fontWeight="bold" gutterBottom>
                Instrucciones Especiales:
              </Typography>
              <Typography variant="body2" sx={{ backgroundColor: '#f9f9f9', p: 2, borderRadius: 1 }}>
                {order.special_instructions}
              </Typography>
            </Box>
          )}

          {order.estimated_cost && (
            <Box sx={{ mb: 2 }}>
              <Typography variant="body1" fontWeight="bold" gutterBottom>
                Costo Estimado:
              </Typography>
              <Typography variant="body2" sx={{ backgroundColor: '#e8f5e8', p: 2, borderRadius: 1 }}>
                {order.estimated_cost}
              </Typography>
            </Box>
          )}
        </Box>
      )}

      <Divider sx={{ mb: 3 }} />

      {/* Footer */}
      <Box sx={{ mt: 4 }}>
        <Grid container spacing={4}>
          <Grid xs={6}>
            <Box sx={{ textAlign: 'center', borderTop: '1px solid #000', pt: 1 }}>
              <Typography variant="body2" fontWeight="bold">
                {doctorInfo?.title || 'Dr.'} {order.ordering_doctor_name}
              </Typography>
              <Typography variant="caption">
                Cédula Profesional: {order.ordering_doctor_license}
              </Typography>
            </Box>
          </Grid>
          <Grid xs={6}>
            <Box sx={{ textAlign: 'center', borderTop: '1px solid #000', pt: 1 }}>
              <Typography variant="body2" fontWeight="bold">
                FIRMA DIGITAL
              </Typography>
              <Typography variant="caption">
                Fecha: {formatDateTime(order.order_date)}
              </Typography>
            </Box>
          </Grid>
        </Grid>
      </Box>

      {/* Nota Legal */}
      <Box sx={{ mt: 3, p: 1, backgroundColor: '#f5f5f5', borderRadius: 1 }}>
        <Typography variant="caption" sx={{ fontSize: '10px' }}>
          * Documento generado conforme a la NOM-004-SSA3-2012 del Expediente Clínico. 
          Esta orden médica tiene validez únicamente con la firma del médico tratante y debe ser presentada en el laboratorio o centro de estudios correspondiente.
          {order.valid_until_date && ` Válida hasta: ${formatDate(order.valid_until_date)}`}
        </Typography>
      </Box>
    </Paper>
  );
};

export default MedicalOrderPrintFormat;
